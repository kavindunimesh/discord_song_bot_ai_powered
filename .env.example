# SIMILAR_PROVIDER=gemini
# SIMILAR_PROVIDER=custom

# cursor (default)
CURSOR_API_KEY=
# CURSOR_MODEL=composer-2.5

# openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# custom HTTP provider — POST { song, artist, limit }
# CUSTOM_SIMILAR_URL=https://example.com/similar
# CUSTOM_SIMILAR_API_KEY=
